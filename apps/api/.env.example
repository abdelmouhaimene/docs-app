# =====================================================
# NestJS API - LOCAL DEVELOPMENT
# Copy this to .env for local npm run api:dev
# =====================================================
# This is for running backend OUTSIDE Docker
# When using Docker, values come from root .env
# NOT COMMITTED TO GIT (already in .gitignore)

# Application Mode
NODE_ENV=development
PORT=3001

# MongoDB (local MongoDB instance)
MONGODB_URI=mongodb://localhost:27017/mca_docs_dev

# JWT Authentication (development key - change in production)
JWT_SECRET=dev-secret-key-change-in-production-minimum-32-characters-long
JWT_EXPIRATION=7d

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# CORS (allow requests from local frontend)
CORS_ORIGIN=http://localhost:3000

# API Configuration
API_PREFIX=/api/v1
