# =====================================================
# DEVELOPMENT ENVIRONMENT - Docker Compose
# Copy this to .env for local development with Docker
# =====================================================
# This file is for LOCAL DEVELOPMENT ONLY
# For production, use: .env.production
# For staging, use: .env.staging
# NOT COMMITTED TO GIT (already in .gitignore)

# MongoDB Configuration (Docker internal)
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=admin123
MONGO_DATABASE=mca_docs_dev

# Service Ports (for local development)
API_PORT=3001
CLIENT_PORT=3000
MONGO_EXPRESS_PORT=8081
